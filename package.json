{
  "name": "@edvintoome/meta-mcp",
  "version": "1.7.2",
  "description": "Model Context Protocol server for Meta Marketing API integration",
  "main": "meta-mcp/build/index.js",
  "type": "module",
  "bin": {
    "meta-mcp": "meta-mcp/scripts/cli.js",
    "gemini-creative-mcp": "meta-mcp/build/gemini-index.js"
  },
  "scripts": {
    "build": "tsup --config meta-mcp/tsup.config.ts",
    "dev": "tsx meta-mcp/src/index.ts",
    "dev:gemini": "tsx gemini-mcp/src/gemini-index.ts",
    "dev:vercel": "vercel dev",
    "test": "jest --config meta-mcp/jest.config.js",
    "test:tools": "tsx meta-mcp/test-tools.js",
    "list:tools": "tsx meta-mcp/list-tools.js",
    "test:api": "tsx meta-mcp/test-api.js",
    "lint": "eslint meta-mcp/src/**/*.ts",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "vercel-build": "npm run build",
    "setup": "node meta-mcp/scripts/setup-mcp.js",
    "setup:mcp": "node meta-mcp/scripts/setup-mcp.js",
    "setup:codex-plugin": "node meta-mcp/scripts/setup-codex-plugin.js",
    "setup:claude": "node meta-mcp/scripts/setup-claude.js",
    "init:workspace": "node meta-mcp/scripts/init-workspace-config.js",
    "health-check": "node meta-mcp/scripts/health-check.js",
    "check": "node meta-mcp/scripts/health-check.js",
    "structured-build": "tsx meta-mcp/scripts/run-structured-build.ts"
  },
  "author": "Edvin Toome",
  "license": "MIT",
  "files": [
    "meta-mcp/build",
    "meta-mcp",
    "agents",
    "templates",
    ".codex-plugin",
    ".claude-plugin",
    ".mcp.json",
    "AGENTS.md",
    "README.md",
    "LICENSE",
    "scripts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EdvinToome/meta-mcp.git"
  },
  "homepage": "https://github.com/EdvinToome/meta-mcp#readme",
  "bugs": {
    "url": "https://github.com/EdvinToome/meta-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "meta",
    "facebook",
    "instagram",
    "advertising",
    "marketing-api"
  ],
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@vercel/kv": "^3.0.0",
    "@vercel/mcp-adapter": "^0.11.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "jose": "^6.1.3",
    "node-fetch": "^3.3.2",
    "redis": "^5.10.0",
    "sharp": "^0.34.4",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.28",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
